# Apartment Bookings Backend - Environment Configuration

# Server
NODE_ENV=development
PORT=3000

# Database (PostgreSQL + Prisma)
DATABASE_URL="postgresql://username:password@localhost:5432/apartment_bookings?schema=public"

# Redis (Cache & Queues)
REDIS_URL=redis://localhost:6379

# JWT Auth
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Cloudinary (File Storage)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Email (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# BullMQ Queue (Redis already configured)
BULL_PREFIX=apartment-bookings

# Rate Limiting
RATE_LIMIT_WINDOW_MS=15 * 60 * 1000  # 15 minutes
RATE_LIMIT_MAX=100

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Logging
LOG_LEVEL=info

# Other
CORN_SECRET=your-cron-secret
